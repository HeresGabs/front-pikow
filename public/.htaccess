<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Ne pas réécrire les fichiers et dossiers existants (assets, favicon, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Toutes les autres routes sont gérées par le routeur Vue -> index.html
  RewriteRule ^ index.html [L]
</IfModule>
